# Statesmen AI — environment template
#
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored. Both runtime (Next.js API routes) and CLI scripts (in
# `scripts/`) load these variables.

# ─── LLMs ─────────────────────────────────────────────────────────────────────

# OpenRouter — used for offline-style style extraction during persona builds.
# Get a key at https://openrouter.ai/keys
# Model used: anthropic/claude-3.5-sonnet (or override via OPENROUTER_EXTRACT_MODEL)
OPENROUTER_API_KEY=

# Optional master fallback list (comma-separated). The pipeline tries each
# model in order; if a call fails with a transient/rate-limit error, the
# next model is tried. Free-tier OpenRouter models are 1 RPM per model, so
# listing 2-3 free models gives you cumulative RPM and resilience when
# upstream providers throttle one of them.
# OPENROUTER_MODELS=nvidia/nemotron-3-super-120b-a12b:free,qwen/qwen3-next-80b-a3b-instruct:free,nvidia/nemotron-nano-9b-v2:free

# Optional master single-model override (used if OPENROUTER_MODELS is unset).
# OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Optional per-stage overrides (take precedence over the master vars above).
# Either accepts a single id OR a comma-separated list.
# OPENROUTER_EXTRACT_MODELS=anthropic/claude-haiku-4.5,anthropic/claude-sonnet-4.5
# OPENROUTER_MERGE_MODELS=anthropic/claude-opus-4.5
# OPENROUTER_EXTRACT_MODEL=anthropic/claude-sonnet-4.5
# OPENROUTER_MERGE_MODEL=anthropic/claude-opus-4.5

# Groq — used for low-latency streaming chat with the persona.
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional: override the chat model.
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# ─── Storage ──────────────────────────────────────────────────────────────────

# Vercel Blob — stores cached persona MD + examples files in production.
# Generated automatically when you create a Blob store on Vercel.
# In local dev (when this is empty) the cache falls back to data/personas/.
BLOB_READ_WRITE_TOKEN=
