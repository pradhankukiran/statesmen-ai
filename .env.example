# Statesmen AI — environment template
#
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored. Both runtime (Next.js API routes) and CLI scripts (in
# `scripts/`) load these variables.

# ─── LLMs ─────────────────────────────────────────────────────────────────────

# OpenRouter — used for offline-style style extraction during persona builds.
# Get a key at https://openrouter.ai/keys
# Model used: anthropic/claude-3.5-sonnet (or override via OPENROUTER_EXTRACT_MODEL)
OPENROUTER_API_KEY=

# Optional: override the extraction model (any OpenRouter model id).
# OPENROUTER_EXTRACT_MODEL=anthropic/claude-3.5-sonnet

# Groq — used for low-latency streaming chat with the persona.
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional: override the chat model.
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# ─── Storage ──────────────────────────────────────────────────────────────────

# Vercel Blob — stores cached persona MD + examples files in production.
# Generated automatically when you create a Blob store on Vercel.
# In local dev (when this is empty) the cache falls back to data/personas/.
BLOB_READ_WRITE_TOKEN=
