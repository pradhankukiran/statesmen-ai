# Statesmen AI — environment template
#
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored. Both runtime (Next.js API routes) and CLI scripts (in
# `scripts/`) load these variables.

# ─── LLMs ─────────────────────────────────────────────────────────────────────

# Modal-hosted Qwen3.6-27B (llama.cpp, OpenAI-compatible) — preferred provider
# for the offline BUILD pipeline (extract + merge). When set, the pipeline
# tries Modal first and falls back to Groq on transient/parse failures. Chat
# streaming always uses Groq (see GROQ_CHAT_MODEL below). Leave blank to
# disable the Modal tier entirely and use Groq-only for build.
MODAL_LLAMA_URL=
# Bearer token for Modal — sent as `Authorization: Bearer <key>`.
MODAL_LLAMA_API_KEY=
# Optional override for the served model name. Default: qwen3.6-27b
# MODAL_LLAMA_MODEL=qwen3.6-27b

# Groq — used for the realtime CHAT pipeline AND as fallback for BUILD when
# Modal is unconfigured or unavailable. Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional: override the chat model. Streaming chat — any Groq chat model.
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Optional master fallback list (comma-separated) for the extract+merge
# pipeline. The pipeline tries each model in order; if a call fails with a
# transient/rate-limit error, the next model is tried. Must list only models
# that support response_format=json_schema on Groq — see
# https://console.groq.com/docs/structured-outputs#supported-models
# Default: openai/gpt-oss-120b, meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_MODELS=openai/gpt-oss-120b,meta-llama/llama-4-scout-17b-16e-instruct

# Optional per-stage overrides (take precedence over GROQ_MODELS).
# GROQ_EXTRACT_MODELS=openai/gpt-oss-120b
# GROQ_MERGE_MODELS=openai/gpt-oss-120b
# GROQ_EXTRACT_MODEL=openai/gpt-oss-120b
# GROQ_MERGE_MODEL=openai/gpt-oss-120b

# ─── Storage ──────────────────────────────────────────────────────────────────

# Vercel Blob — stores cached persona MD + examples files in production.
# Generated automatically when you create a Blob store on Vercel.
# In local dev (when this is empty) the cache falls back to data/personas/.
BLOB_READ_WRITE_TOKEN=
